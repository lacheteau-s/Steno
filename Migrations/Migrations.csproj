    <Nullable>enable</Nullable>
    <UserSecretsId>c3e7bda9-79cc-4c64-8373-674f5306eca4</UserSecretsId>
  </PropertyGroup>

  <ItemGroup>
    <PackageReference Include="Dapper" Version="2.1.66" />
